# .env.template — New Server (np-dms-lcbp3 / 192.168.10.11)
# วิธีใช้:
#   1. copy ไฟล์นี้เป็น `.env` ในโฟลเดอร์เดียวกับ docker-compose ที่จะ deploy
#   2. แทนค่า CHANGE_ME_* ทุกตัวด้วยค่าจริง (ห้าม commit `.env`)
#   3. สร้าง secret 32-byte ด้วย: `openssl rand -hex 32`
# หมายเหตุ: ไฟล์นี้ต้องไม่มีค่า secret จริงเด็ดขาด (Tier-1 Security)
# ความแตกต่างจาก QNAP .env.template:
#   - DB_HOST เปลี่ยนเป็น 'mariadb' (Docker internal DNS — ไม่ใช่ LAN IP)
#   - OCR_API_URL เปลี่ยนเป็น 'http://ocr-sidecar:8765' (Docker internal)
#   - OLLAMA_API_URL เปลี่ยนเป็น 'http://192.168.10.11:11434' (native systemd Ollama — ไม่ใช่ Docker)
#   - ASUSTOR CIFS mount สำหรับ uploads (ASUSTOR = Primary NAS)

# ---------------------------------------------------------
# 1. Backend Service Configuration
# ---------------------------------------------------------
TZ=Asia/Bangkok
NODE_ENV=production
PORT=3000

# --- Database (MariaDB) ---
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=lcbp3
DB_USERNAME=center
# strong password ≥ 16 chars, mixed case + symbol + digit
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
# ใช้คนละค่ากับ DB_PASSWORD (least privilege)
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

# --- Redis (Cache & Queue) ---
REDIS_HOST=cache
REDIS_PORT=6379
# Redis server จะถูกเริ่มด้วย --requirepass ${REDIS_PASSWORD}
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Search (Elasticsearch) ---
ELASTICSEARCH_HOST=search
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=CHANGE_ME_ES_PASSWORD

# --- Security (JWT) — backend only, อย่าใช้ค่าซ้ำกับ AUTH_SECRET ---
# generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRATION=8h
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET

# --- ClamAV (File upload scanning, ADR-016) ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# --- Qdrant (Vector Database for RAG — ADR-023A) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# --- OCR Sidecar (Docker internal — ADR-040 D5) ---
OCR_API_URL=http://ocr-sidecar:8765
OCR_CHAR_THRESHOLD=100
OCR_SIDECAR_API_KEY=CHANGE_ME_OCR_SIDECAR_API_KEY
OCR_SIDECAR_UPLOAD_BASE=/mnt/uploads

# --- Ollama (native systemd service — D11, ไม่ใช่ Docker) ---
# Ollama รันเป็น systemd service บน host — backend container เรียกผ่าน host IP
OLLAMA_URL=http://192.168.10.11:11434

# --- Numbering Logic ---
NUMBERING_LOCK_TIMEOUT=5000
NUMBERING_RESERVATION_TTL=300

# --- CORS (Backend accepts requests from frontend) ---
CORS_ORIGIN=https://lcbp3.np-dms.work,http://192.168.10.11:3001,http://localhost:3001,http://127.0.0.1:3001

# --- File Storage ---
UPLOAD_TEMP_DIR=/app/uploads/temp
UPLOAD_PERMANENT_DIR=/app/uploads/permanent
MAX_FILE_SIZE=52428800

# ---------------------------------------------------------
# 2. Frontend Service Configuration
# ---------------------------------------------------------
NEXT_PUBLIC_API_URL=http://192.168.10.11:3000/api
AUTH_URL=https://lcbp3.np-dms.work

# --- NextAuth — ห้ามตั้งค่าเดียวกับ JWT_SECRET ---
# generate: openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_AUTH_SECRET
AUTH_TRUST_HOST=true

# --- Shared Context ---
INTERNAL_API_URL=http://backend:3000/api
HOSTNAME=0.0.0.0

# ---------------------------------------------------------
# 3. Infrastructure (อ้างอิงจาก compose files)
# ---------------------------------------------------------
# n8n
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY
N8N_DB_PASSWORD=CHANGE_ME_N8N_DB_PASSWORD

# Gitea (DB user)
GITEA_DB_PASSWORD=CHANGE_ME_GITEA_DB_PASSWORD

# NPM (DB user — NPM อยู่ QNAP แต่ใช้ MariaDB บน New Server)
NPM_DB_PASSWORD=CHANGE_ME_NPM_DB_PASSWORD

# ASUSTOR CIFS mount (Primary NAS — ADR-041 D2)
ASUSTOR_USER=CHANGE_ME_ASUSTOR_USER
ASUSTOR_PASS=CHANGE_ME_ASUSTOR_PASS

# ---------------------------------------------------------
# 4. M-phase additions
# ---------------------------------------------------------
# App image tags (CI-injected per release)
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# OCR Sidecar (ADR-040 Phase 4+6)
OCR_ACTIVE_PROFILE=
VRAM_HEADROOM_THRESHOLD_MB=3000.0
OCR_RESIDENCY_WINDOW_SECONDS=120
GPU_TOTAL_VRAM_MB=16384.0
GPU_MAIN_MODEL_PRESSURE_THRESHOLD_MB=12000.0
RETRIEVAL_TIMEOUT_SECONDS=30.0
OCR_MODEL=np-dms-ocr:latest
OCR_TIMEOUT=360
