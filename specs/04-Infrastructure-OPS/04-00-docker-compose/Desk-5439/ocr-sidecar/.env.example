# File: specs/04-Infrastructure-OPS/04-00-docker-compose/Desk-5439/ocr-sidecar/.env.example
# QNAP NAS SMB credentials สำหรับ CIFS named volume
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น git

QNAP_SMB_USER=your_qnap_username
QNAP_SMB_PASS=your_qnap_password

# OCR Sidecar security and storage boundary
OCR_SIDECAR_API_KEY=change-me-sidecar-api-key
OCR_SIDECAR_UPLOAD_BASE=/mnt/uploads

